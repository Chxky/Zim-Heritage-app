# ZimHeritage Environment Configuration
# Copy this to .env and fill in your values.

# Set to "true" to use Firebase (real backend), "false" for offline mock mode
USE_FIREBASE=false

# Gemini AI is proxied through a Firebase Cloud Function in production.
# Set a key here only for local development (not needed if GEMINI_FUNCTION_URL is set):
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Cloud Function URL (leave empty to use local API key or fallback)
GEMINI_FUNCTION_URL=

# Sentry DSN for error monitoring (get one at https://sentry.io)
SENTRY_DSN=

# Default app locale (en, sn, nd)
APP_LOCALE=en
